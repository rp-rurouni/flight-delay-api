[\"origin_fallback\"]\n","DEST_FALLBACK = loaded[\"dest_fallback\"]\n","\n","print(\"✅ Loaded bundle and restored artifacts\")\n","print(\"Threshold:\", FINAL_THRESHOLD)\n","print(\"Num features:\", len(FEATURE_COLS))"]},{"cell_type":"code","execution_count":45,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"T-htLU35J01f","outputId":"054acbb6-92ef-4d8a-e66b-bbe170589c81","executionInfo":{"status":"ok","timestamp":1772505859487,"user_tz":420,"elapsed":88,"user":{"displayName":"Rahul Poddar","userId":"16898856394564443611"}}},"outputs":[{"output_type":"execute_result","data":{"text/plain":["{'label': '🟩 On-time (<15 min arrival delay)',\n"," 'delay_probability': 0.21626865648315927,\n"," 'threshold': 0.32077}"]},"metadata":{},"execution_count":45}],"source":["import joblib\n","import pandas as pd\n","\n","# Load the bundle to get model and preprocessing artifacts\n","loaded = joblib.load(\"flight_delay_bundle.joblib\")\n","\n","final_model = loaded[\"model\"]\n","FINAL_THRESHOLD = loaded[\"threshold\"]\n","FEATURE_COLS = loaded[\"feature_cols\"]\n","ORIGIN_DELAY_MAP = loaded[\"origin_delay_map\"]\n","DEST_DELAY_MAP = loaded[\"dest_delay_map\"]\n","ORIGIN_FALLBACK = loaded[\"origin_fallback\"]\n","DEST_FALLBACK = loaded[\"dest_fallback\"]\n","\n","def preprocess_single_flight(raw: dict) -> pd.DataFrame:\n","    \"\"\"\n","    Convert a single flight input dict into a 1-row DataFrame\n","    with EXACTLY the same columns as FEATURE_COLS.\n","    \"\"\"\n","\n","    df = pd.DataFrame([raw]).copy()\n","\n","    # --- Match training feature engineering ---\n","    # Departure hour from HHMM\n","    df[\"DEP_HOUR\"] = (df[\"SCHEDULED_DEPARTURE\"] // 100).astype(int)\n","    df[\"DEP_HOUR\"] = df[\"DEP_HOUR\"].clip(lower=0, upper=23)\n","\n","    # Weekend flag (only if present in training)\n","    if \"IS_WEEKEND\" in FEATURE_COLS:\n","        df[\"IS_WEEKEND\"] = df[\"DAY_OF_WEEK\"].isin([6, 7]).astype(int)\n","\n","    # --- Target encoding for airports ---\n","    df[\"ORIGIN_ENCODED\"] = df[\"ORIGIN_AIRPORT\"].map(ORIGIN_DELAY_MAP).fillna(ORIGIN_FALLBACK)\n","    df[\"DEST_ENCODED\"]   = df[\"DESTINATION_AIRPORT\"].map(DEST_DELAY_MAP).fillna(DEST_FALLBACK)\n","\n","    # --- One-hot encoding for AIRLINE (drop_first=True behavior) ---\n","    airline_cols = [c for c in FEATURE_COLS if c.startswith(\"AIRLINE_\")]\n","    for col in airline_cols:\n","        df[col] = 0\n","\n","    airline = df.loc[0, \"AIRLINE\"]\n","    airline_col = f\"AIRLINE_{airline}\"\n","    if airline_col in airline_cols:\n","        df.loc[0, airline_col] = 1\n","\n","    # --- Drop raw string / unused columns ---\n","    drop_cols = [\"AIRLINE\", \"ORIGIN_AIRPORT\", \"DESTINATION_AIRPORT\", \"SCHEDULED_DEPARTURE\"]\n","    for col in drop_cols:\n","        if col in df.columns:\n","            df = df.drop(columns=[col])\n","\n","    # --- Add any missing columns ---\n","    for col in FEATURE_COLS:\n","        if col not in df.columns:\n","            df[col] = 0\n","\n","    # --- Enforce exact column order ---\n","    df = df[FEATURE_COLS]\n","\n","    return df\n","\n","def predict_single_flight(raw: dict,\n","                          model=final_model,\n","                          threshold: float = FINAL_THRESHOLD):\n","    \"\"\"\n","    Predict delay status for one flight using the SAME preprocessing as training.\n","    \"\"\"\n","\n","    X_one = preprocess_single_flight(raw)\n","\n","    # Probability flight is delayed (class 1)\n","    proba = float(model.predict_proba(X_one)[0, 1])\n","\n","    pred = int(proba >= threshold)\n","\n","    label = \"🟥 Delayed (>=15 min arrival delay)\" if pred == 1 else \"🟩 On-time (<15 min arrival delay)\"\n","    return {\"label\": label, \"delay_probability\": proba, \"threshold\": threshold}\n","\n","example_flight = {\n","    \"MONTH\": 6,\n","    \"DAY\": 15,\n","    \"DAY_OF_WEEK\": 1,\n","    \"AIRLINE\": \"AS\",\n","    \"ORIGIN_AIRPORT\": \"SEA\",\n","    \"DESTINATION_AIRPORT\": \"ANC\",\n","    \"SCHEDULED_DEPARTURE\": 1430,  # HHMM\n","    \"SCHEDULED_TIME\": 180,\n","    \"DISTANCE\": 1448,\n","    \"CANCELLED\": 0,\n","    \"DIVERTED\": 0\n","}\n","raw_example = example_flight\n","predict_single_flight(raw_example)"]},{"cell_type":"markdown","source":["Real-World Flight Delay Prediction"],"metadata":{"id":"ZXBFUWVeHYKO"}},{"cell_type":"code","execution_count":46,"metadata":{"id":"C4ICYq7pxCQl","executionInfo":{"status":"ok","timestamp":1772505867815,"user_tz":420,"elapsed":14,"user":{"displayName":"Rahul Poddar","userId":"16898856394564443611"}}},"outputs":[],"source":["def predict_from_inputs(\n","    airline: str,\n","    origin_airport: str,\n","    destination_airport: str,\n","    month: int,\n","    day: int,\n","    day_of_week: int,\n","    scheduled_departure_hhmm: int,\n","    scheduled_time_minutes: float,\n","    distance: float,\n","    cancelled: int = 0,\n","    diverted: int = 0,\n","):\n","    \"\"\"\n","    Predict delay (>=15 min arrival delay) using only pre-departure inputs.\n","    This matches the training feature engineering + encoding.\n","    \"\"\"\n","\n","    # --- derive engineered features exactly like training ---\n","    hhmm = int(scheduled_departure_hhmm)\n","\n","    # Accept both HHMM (e.g., 1345) and plain hour (0–23)\n","    if 0 <= hhmm <= 23:\n","      dep_hour = hhmm\n","    else:\n","      dep_hour = hhmm // 100\n","\n","    dep_hour = min(max(dep_hour, 0), 23)\n","\n","    is_weekend = 1 if day_of_week in [6, 7] else 0\n","\n","    # --- airport target encoding using frozen maps + fallbacks ---\n","    origin_encoded = ORIGIN_DELAY_MAP.get(origin_airport, ORIGIN_FALLBACK)\n","    dest_encoded = DEST_DELAY_MAP.get(destination_airport, DEST_FALLBACK)\n","\n","    # --- one-hot airline exactly like pd.get_dummies(drop_first=True) did ---\n","    # Find the dummy column name format used in training: AIRLINE_XX\n","    airline_col = f\"AIRLINE_{airline}\"\n","\n","    # Start with all-zero feature row\n","    row = {c: 0 for c in FEATURE_COLS}\n","\n","    # Fill numeric / base features that exist in your training matrix\n","    # (Only set keys if they exist, to avoid KeyError if your notebook differs slightly.)\n","    for k, v in {\n","        \"MONTH\": month,\n","        \"DAY\": day,\n","        \"DAY_OF_WEEK\": day_of_week,\n","        \"DEP_HOUR\": dep_hour,\n","        \"IS_WEEKEND\": is_weekend,\n","        \"DISTANCE\": distance,\n","        \"SCHEDULED_TIME\": scheduled_time_minutes,\n","        \"CANCELLED\": cancelled,\n","        \"DIVERTED\": diverted,\n","        \"ORIGIN_ENCODED\": origin_encoded,\n","        \"DEST_ENCODED\": dest_encoded,\n","    }.items():\n","        if k in row:\n","            row[k] = v\n","\n","    # Set the airline dummy if it exists.\n","    # Note: because drop_first=True, one airline becomes the \"baseline\" with no column.\n","    if airline_col in row:\n","        row[airline_col] = 1\n","\n","    # Create 1-row dataframe in exact training column order\n","    X_one = pd.DataFrame([row], columns=FEATURE_COLS)\n","\n","    # Predict probability of \"delayed\" class (class=1)\n","    proba = float(final_model.predict_proba(X_one)[:, 1][0])\n","\n","    label = \"🟥 Delayed (>=15 min arrival delay)\" if proba >= FINAL_THRESHOLD else \"🟩 On-time (<15 min arrival delay)\"\n","\n","    return {\n","        \"label\": label,\n","        \"delay_probability\": proba,\n","        \"threshold\": float(FINAL_THRESHOLD),\n","        \"inputs_used\": {\n","            \"airline\": airline,\n","            \"origin_airport\": origin_airport,\n","            \"destination_airport\": destination_airport,\n","            \"month\": month,\n","            \"day\": day,\n","            \"day_of_week\": day_of_week,\n","            \"scheduled_departure_hhmm\": scheduled_departure_hhmm,\n","            \"dep_hour\": dep_hour,\n","            \"scheduled_time_minutes\": scheduled_time_minutes,\n","            \"distance\": distance,\n","            \"cancelled\": cancelled,\n","            \"diverted\": diverted\n","        }\n","    }\n"]},{"cell_type":"code","execution_count":47,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"CUmyynJ_xO5M","executionInfo":{"status":"ok","timestamp":1772505875423,"user_tz":420,"elapsed":23,"user":{"displayName":"Rahul Poddar","userId":"16898856394564443611"}},"outputId":"1fa88635-838b-4997-e602-3df519433644"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["{'label': '🟩 On-time (<15 min arrival delay)',\n"," 'delay_probability': 0.17262510487791707,\n"," 'threshold': 0.32077,\n"," 'inputs_used': {'airline': 'AA',\n","  'origin_airport': 'LAX',\n","  'destination_airport': 'PBI',\n","  'month': 1,\n","  'day': 1,\n","  'day_of_week': 4,\n","  'scheduled_departure_hhmm': 10,\n","  'dep_hour': 10,\n","  'scheduled_time_minutes': 300,\n","  'distance': 2330,\n","  'cancelled': 0,\n","  'diverted': 0}}"]},"metadata":{},"execution_count":47}],"source":["predict_from_inputs(\n","    airline=\"AA\",\n","    origin_airport=\"LAX\",\n","    destination_airport=\"PBI\",\n","    month=1,\n","    day=1,\n","    day_of_week=4,\n","    scheduled_departure_hhmm=10,\n","    scheduled_time_minutes=300,\n","    distance=2330,\n","    cancelled=0,\n","    diverted=0\n",")"]},{"cell_type":"markdown","metadata":{"id":"6SGD1u8OV10y"},"source":["## 9: Final Test Set Prediction"]},{"cell_type":"code","execution_count":48,"metadata":{"id":"bQTvLvs8V10y","colab":{"base_uri":"https://localhost:8080/","height":636},"executionInfo":{"status":"ok","timestamp":1772505898297,"user_tz":420,"elapsed":15890,"user":{"displayName":"Rahul Poddar","userId":"16898856394564443611"}},"outputId":"fe5c7361-1c2b-435e-d839-9bb80431c169"},"outputs":[{"output_type":"stream","name":"stdout","text":["✅ Final Test Accuracy: 0.8238644825871673\n","\n","📋 Classification Report:\n","\n","              precision    recall  f1-score   support\n","\n","           0       0.83      0.9